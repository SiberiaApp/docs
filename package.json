    "@fontsource/bebas-neue": "^5.2.7",
    "@orama/orama": "^3.1.18",
    "@orama/stopwords": "^3.1.18",
    "@orama/tokenizers": "^3.1.18",
    "fumadocs-core": "16.7.9",
    "fumadocs-mdx": "14.2.11",
    "fumadocs-ui": "16.7.9",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.1.0",
    "eslint-config-next": "16.2.1",
    "postcss": "^8.5.8",
    "serve": "^14.2.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
